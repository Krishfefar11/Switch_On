# ─────────────────────────────────────────────────────────────
#  feature-flag-api — .gitignore
#  This file covers standalone deployments (e.g. Railway, Render)
#  where only this directory is the git root.
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Environment — secrets live here, NEVER commit
.env
.env.*
!.env.example

# Build output
dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Runtime
pids/
*.pid

# OS files
.DS_Store
Thumbs.db

# Test artefacts
coverage/
.nyc_output/
