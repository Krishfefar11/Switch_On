# ── Port ──────────────────────────────────────────────
PORT=8080

# ── API ───────────────────────────────────────────────
# Your Railway API URL (no trailing slash)
API_URL=https://your-api.railway.app

# ── SDK Key ───────────────────────────────────────────
# Use the development SDK key from Settings > SDK Keys in the dashboard
CONSUMER_API_KEY=sdk-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Environment ───────────────────────────────────────
FLAG_ENVIRONMENT=development

# ── Dashboard link shown in demo header ───────────────
DASHBOARD_URL=https://your-dashboard.vercel.app
